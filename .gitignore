# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]

# Claude Code per-user settings
.claude/settings.json
.claude/settings.local.json
.claude/worktrees/

# Supabase CLI local cache
supabase/.temp/

# Scratch / sample data
/tmp/

# Playwright E2E artefacts
/e2e/.auth/
/e2e-prod/.auth/
/playwright-report/
/test-results/
/playwright/.cache/

# Uploaded content during dev (Supabase Storage mirrors should not leak in)
/content-uploads/
/.course-import-state/

# BMH course video assets — regenerable build outputs, not versioned (recipe lives in docs/course-production/shotlists)
course-assets/
