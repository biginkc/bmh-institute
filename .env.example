# BMH Institute — environment variables

# Production Supabase project: bmh-institute (BMH Group org)
NEXT_PUBLIC_SUPABASE_URL=https://dhvfsyteqsxagokoerrx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRodmZzeXRlcXN4YWdva29lcnJ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY5NzY2MTIsImV4cCI6MjA5MjU1MjYxMn0.HzMJIZolBNHNnPKf-iUijXJ4b2gRtUypXaCP6YJVJtg

# Service role key — grab from Supabase Dashboard → Project Settings → API.
# DO NOT commit real values. Used only by edge functions, server actions, and admin-only RPCs.
SUPABASE_SERVICE_ROLE_KEY=replace_me

# App base URL (used in invite and notification emails)
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Vercel Cron sends this as Authorization: Bearer <secret> to scheduled routes.
# Generate a long random value; never expose it through NEXT_PUBLIC_*.
CRON_SECRET=replace_with_long_random_cron_secret

# Closer Lab role-play embeds.
# Local/test-only legacy fallback. Production refuses this shared key.
ROLE_PLAY_JWT_SECRET=
# BMH Institute signs Closer Lab admission tokens with this key.
ROLE_PLAY_EMBED_SIGNING_SECRET=replace_with_32_plus_byte_embed_secret
# BMH Institute verifies Closer Lab completion proofs with these keys.
ROLE_PLAY_COMPLETION_VERIFY_SECRET=replace_with_32_plus_byte_completion_secret
# Previous completion verification is accepted only until an ISO cutoff no more than 15 minutes ahead.
ROLE_PLAY_COMPLETION_PREVIOUS_SECRET=
ROLE_PLAY_COMPLETION_PREVIOUS_SECRET_VALID_UNTIL=
NEXT_PUBLIC_ROLE_PLAY_BASE_URL=http://localhost:3200

# Transactional email via Google Workspace SMTP.
# Create an app password at https://myaccount.google.com/apppasswords
# (requires 2FA on the Workspace account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=jarrad@bmhgroupkc.com
SMTP_PASS=replace_me
SMTP_FROM_EMAIL=jarrad@bmhgroupkc.com
SMTP_FROM_NAME=BMH Institute

# Admins — comma-separated list of emails that automatically get system_role='owner' or 'admin'.
# Defaults to jarrad@bmhgroupkc.com. Safe to leave blank during initial dev.
ADMIN_EMAILS=jarrad@bmhgroupkc.com

# --- Claude's prod verification harness (Playwright) ---
# Populate these in .env.test.local (never commit) so `npm run test:prod` can
# log into the live deployment and verify authenticated surfaces. Read-only
# specs only — this uses a real account against the production Supabase.
# E2E_PROD_BASE_URL=https://institute.bmhgroupkc.com
# E2E_TEST_EMAIL=your@email.com
# E2E_TEST_PASSWORD=your_password

# --- Production readiness harness ---
# This workflow writes disposable prefixed data to production and cleans it up.
# It must point at the production Supabase project and real deployed app.
# PROD_SUPABASE_URL=https://dhvfsyteqsxagokoerrx.supabase.co
# PROD_SUPABASE_ANON_KEY=
# PROD_SUPABASE_SERVICE_ROLE_KEY=
# PROD_READINESS_TEST_PASSWORD=
# PROD_READINESS_EMAIL_INBOX=
# PROD_READINESS_EMAIL_IMAP_USER=
# PROD_READINESS_EMAIL_IMAP_PASS=
# PROD_READINESS_EMAIL_IMAP_HOST=imap.gmail.com
# PROD_READINESS_EMAIL_IMAP_PORT=993
# PROD_READINESS_EMAIL_IMAP_SECURE=true
# PROD_READINESS_EMAIL_MAILBOX=INBOX

# --- Local Vitest integration suite + `npm run test:e2e` ---
# Populate in .env.test.local. The fixtures in e2e/fixtures.ts refuse to
# run against the prod project (dhvfsyteqsxagokoerrx). Leave these blank
# unless you are running the integration or Playwright suites locally.
# TEST_SUPABASE_URL=
# TEST_SUPABASE_ANON_KEY=
# TEST_SUPABASE_SERVICE_ROLE_KEY=

# Current non-prod Supabase project for durable E2E work:
# bmh-institute-test, ref jvaabkchkihkjllehmft.
# After populating TEST_SUPABASE_* locally, seed realistic LMS content with:
# npm run seed:e2e
# Local seeded fixture users require E2E_SEED_PASSWORD. There is no
# repository fallback; use a unique value of at least 24 characters.
# E2E_SEED_PASSWORD=
