{
  "name": "bmh-institute",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "course:artwork:replace": "tsx scripts/course-content/replace-imported-lesson-artwork.ts",
    "course:video-posters:replace": "tsx scripts/course-content/replace-imported-video-posters.ts",
    "course:video-posters:reconcile-canary": "tsx scripts/course-content/reconcile-canary-video-poster.ts",
    "course:video-posters:capture-preflight": "tsx scripts/course-content/capture-video-poster-production-preflight.ts",
    "dev": "next dev --webpack -p 3100",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:course-import-provider": "tsx scripts/test-course-import-provider.ts",
    "test:rtl": "vitest run --config vitest.rtl.config.ts",
    "test:e2e": "playwright test",
    "test:prod": "playwright test --config playwright.prod.config.ts",
    "test:prod:readiness": "playwright test --config playwright.prod-readiness.config.ts",
    "test:prod:dryrun": "playwright test --config playwright.prod-dryrun.config.ts",
    "test:course-content": "node --test content/course-manifests/*.qa.test.mjs scripts/quiz-rebuild/question-bank.qa.test.mjs && python3 scripts/course-content/generate-approved-captions.test.py && uv run --with reportlab==4.4.9 --with pypdf==6.8.0 python scripts/course-content/generate-guides.semantic.test.py && uv run --with reportlab==4.4.9 --with pypdf==6.8.0 python scripts/course-content/generate-guides.py --check",
    "test:quiz-bank": "node --test scripts/quiz-rebuild/question-bank.qa.test.mjs",
    "test:artwork-production": "node --test docs/course-production/thumbnail-pilots/qa/master-review/build-master-review.test.mjs scripts/course-content/artwork-production-workflow.test.mjs scripts/course-content/promote-thumbnail-redesign.test.mjs",
    "artwork:video-stills": "node scripts/course-content/build-artwork-video-contact-sheets.mjs",
    "artwork:production": "node scripts/course-content/artwork-production.mjs",
    "artwork:redesign-review": "node scripts/course-content/build-thumbnail-redesign-review.mjs --check",
    "artwork:redesign-review:write": "node scripts/course-content/build-thumbnail-redesign-review.mjs --write",
    "artwork:redesign:promote": "node scripts/course-content/promote-thumbnail-redesign.mjs promote",
    "artwork:redesign:verify": "node scripts/course-content/promote-thumbnail-redesign.mjs verify",
    "artwork:poster-redesign:promote": "node scripts/course-content/promote-video-poster-redesign.mjs promote",
    "artwork:poster-redesign:verify": "node scripts/course-content/promote-video-poster-redesign.mjs verify",
    "seed:e2e": "tsx scripts/seed-e2e-test-content.ts",
    "cleanup:e2e": "tsx scripts/seed-e2e-test-content.ts --cleanup-only",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run test:rtl",
    "prepare": "husky",
    "backfill:sanitize-html": "tsx scripts/backfill-sanitize-html.ts",
    "cleanup:prod-readiness": "tsx scripts/cleanup-production-readiness.ts",
    "cleanup:prod-dryrun": "tsx scripts/cleanup-production-readiness.ts --prefix PILOT-DRYRUN-",
    "cleanup:fixtures": "tsx scripts/cleanup-fixture-catalog.ts",
    "cleanup:fixtures:sign": "tsx scripts/sign-fixture-cleanup-evidence.ts",
    "cleanup:fixtures:test-transport": "tsx scripts/fixture-boundary/run-test-project-transport-canary.ts",
    "cleanup:fixtures:test-db-gate": "node scripts/fixture-boundary/run-controller-gate-pr-harness.mjs",
    "cleanup:fixtures:key:provision": "tsx scripts/fixture-boundary/run-verified-production-db-operation.ts provision",
    "cleanup:fixtures:key:retire": "tsx scripts/fixture-boundary/run-verified-production-db-operation.ts retire",
    "cleanup:fixtures:disable": "tsx scripts/fixture-boundary/run-verified-production-db-operation.ts disable",
    "course:import": "tsx scripts/course-import.ts",
    "course:assets:stage": "tsx scripts/course-assets-stage.ts",
    "course:reconcile": "tsx scripts/course-content/build-import-reconciliation-evidence.ts",
    "course:finalize:closer-lab": "node scripts/course-content/finalize-closer-lab-production-mapping.mjs",
    "course:reconcile:closer-lab": "node scripts/course-content/reconcile-closer-lab-production-mapping.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@noble/hashes": "^1.8.0",
    "@sandra/tokens": "github:biginkc/sandra-design-system#main",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.6",
    "shadcn": "^4.4.0",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tus-js-client": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "proper-lockfile": "^4.1.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
